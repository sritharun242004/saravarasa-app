# Secrets — never bake into an image layer
.env
.env.*
!.env.example
*.pem
*.key
aws-credentials*

# Local dev / VCS
.git
.gitignore
venv/
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Runtime data that shouldn't ship in the image (mounted as volumes instead)
uploads/
*.log

# Dev-only scripts / test artifacts not needed at runtime
tests/
test_*.py
test_results.txt

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
