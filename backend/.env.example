# Copy to .env and fill in real values. Never commit .env.

# Database (Neon or local Postgres)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname?sslmode=require

# LLM / OpenRouter (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY
CONTENT_SAFETY_MODEL=nvidia/nemotron-3.5-content-safety:free
LLM_REPORT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Files
INDB_FILE_PATH=../data/Anuvaad_INDB_2024.11.xlsx
UPLOAD_DIR=./uploads

# Auth / CORS
SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
