# Copy to .env and fill in real values. Never commit .env.

# development = keep /docs, /redoc, /openapi.json visible. Leave unset (or
# "production") in any real deployment so they're hidden.
ENVIRONMENT=development

# Database (Neon or local Postgres)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname?sslmode=require

# LLM / OpenRouter (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY
CONTENT_SAFETY_MODEL=nvidia/nemotron-3.5-content-safety:free
LLM_REPORT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Files
INDB_FILE_PATH=../data/Anuvaad_INDB_2024.11.xlsx
UPLOAD_DIR=./uploads

# Auth / CORS
# Required — the app refuses to start without it. Generate a real one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Never reuse this across environments, and rotate it if it may have leaked.
SECRET_KEY=
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── Admin console login ─────────────────────────────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
# Leave both blank in development to use the mock/dev order flow. In
# production the app refuses to skip signature verification if these are unset.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── AWS Cognito + Google OAuth ──────────────────────────────────────────────
# Public identifiers (safe to keep here):
COGNITO_REGION=eu-north-1
COGNITO_USER_POOL_ID=
COGNITO_DOMAIN=
GOOGLE_CLIENT_ID=
# App callback (must be listed as an Allowed callback URL on the Cognito app client):
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
FRONTEND_URL=http://localhost:3000
# Cognito User Pool app-client ID (NOT the Google client id above):
COGNITO_APP_CLIENT_ID=
# Only if your Cognito app client was created WITH a secret (leave blank otherwise):
COGNITO_APP_CLIENT_SECRET=
